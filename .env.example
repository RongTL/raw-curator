# Worker count for ingest / filter / export-jpeg. Leave unset to auto-detect
# (os.cpu_count(), e.g. 8 on a Ryzen 3 3100). Override to throttle if memory
# pressure is an issue: e.g. RAWCURATOR_CPU_WORKERS=4
# RAWCURATOR_CPU_WORKERS=8
RAWCURATOR_PREVIEW_LONG_EDGE=3000
RAWCURATOR_THUMB_LONG_EDGE=512

RAWCURATOR_CLIP_BATCH=8
RAWCURATOR_IQA_BATCH=1

RAWCURATOR_ENHANCE_AI_SCALE=0.6
RAWCURATOR_ENHANCE_TARGET_RES=native
RAWCURATOR_ENHANCE_DENOISE=true
RAWCURATOR_ENHANCE_FACE_RESTORE=true
RAWCURATOR_ENHANCE_CODEFORMER_W=0.7
RAWCURATOR_ENHANCE_OUT_FORMAT=tiff16

RAWCURATOR_PHASH_HAMMING_THRESHOLD=8
RAWCURATOR_CLIP_COSINE_THRESHOLD=0.92
RAWCURATOR_BURST_SECONDS=2

RAWCURATOR_JPEG_QUALITY=92
RAWCURATOR_JPEG_LONG_EDGE=0
RAWCURATOR_JPEG_PROGRESSIVE=true
RAWCURATOR_JPEG_SUBDIR=jpeg
