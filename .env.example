# Worker count for ingest / filter / export-jpeg. Leave unset to auto-detect
# (os.cpu_count(), e.g. 8 on a Ryzen 3 3100). Override to throttle if memory
# pressure is an issue: e.g. RAWCURATOR_CPU_WORKERS=4
# RAWCURATOR_CPU_WORKERS=8
RAWCURATOR_PREVIEW_LONG_EDGE=3000
RAWCURATOR_THUMB_LONG_EDGE=512

RAWCURATOR_CLIP_BATCH=8
RAWCURATOR_IQA_BATCH=1

RAWCURATOR_ENHANCE_AI_SCALE=1.0
RAWCURATOR_ENHANCE_TARGET_RES=200%
RAWCURATOR_ENHANCE_DENOISE=true
# 1.0 = full SCUNet (smoothest). <1 keeps a fraction of original
# micro-texture so the photo doesn't look plastic.
RAWCURATOR_ENHANCE_DENOISE_STRENGTH=0.75
# 1.0 = full Real-ESRGAN (sharpest, most AI-looking). ~0.7 keeps most
# detail recovery while softening the GAN's over-sharpening on natural
# textures; drop to 0.5 for very soft "film-like" output.
RAWCURATOR_ENHANCE_REALESRGAN_FIDELITY=0.7
RAWCURATOR_ENHANCE_FACE_RESTORE=true
# CodeFormer w: higher = more faithful to original skin (natural),
# lower = stronger restoration (waxy/airbrushed risk).
RAWCURATOR_ENHANCE_CODEFORMER_W=0.85
# Backlit recovery: auto-detected via histogram; lifts subject shadows
# while protecting background highlights. Disable if your darktable
# XMPs already handle tone mapping.
RAWCURATOR_ENHANCE_BACKLIT_RECOVERY=true
RAWCURATOR_ENHANCE_BACKLIT_SHADOW_LIFT=0.4
RAWCURATOR_ENHANCE_BACKLIT_HIGHLIGHT_PROTECT=0.15
RAWCURATOR_ENHANCE_OUT_FORMAT=tiff16

RAWCURATOR_PHASH_HAMMING_THRESHOLD=8
RAWCURATOR_CLIP_COSINE_THRESHOLD=0.92
RAWCURATOR_BURST_SECONDS=2

RAWCURATOR_JPEG_QUALITY=92
RAWCURATOR_JPEG_LONG_EDGE=0
RAWCURATOR_JPEG_PROGRESSIVE=true
RAWCURATOR_JPEG_SUBDIR=jpeg
